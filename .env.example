# ─── Polymarket ───────────────────────────────────────────
# Your Polymarket API key (from account settings)
POLYMARKET_API_KEY=your_api_key_here

# Your wallet private key for signing transactions (NEVER share this)
POLYMARKET_PRIVATE_KEY=your_private_key_here

# ─── Binance ──────────────────────────────────────────────
# Binance API key (optional — WebSocket price feeds are public)
BINANCE_API_KEY=your_binance_api_key_here

# ─── Telegram Alerts ─────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token
# Send a message to your bot, then visit:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# to find your chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Bot Configuration (optional) ────────────────────────
# Starting portfolio value in USD (default: 10000)
STARTING_PORTFOLIO=10000

# Set to "true" to enable live trading (default: paper mode)
# LIVE_TRADING=false
